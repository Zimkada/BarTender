# =====================================================
# EDGE FUNCTION ENVIRONMENT VARIABLES (EXAMPLE)
# =====================================================
# Copier ce fichier et configurer les secrets via:
# supabase secrets set KEY=value
# =====================================================

# Resend API Configuration
# Obtenir sur: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Email Configuration
ADMIN_EMAIL=admin@bartender.app
SMTP_FROM=noreply@bartender.app

# Security
# Générer avec: openssl rand -base64 32
FUNCTION_SECRET=your-random-secure-token-here

# Alert Thresholds
ALERT_THRESHOLD=3

# FedaPay (paiements d'abonnement Mobile Money)
# Clés distinctes sandbox/production — obtenir sur https://live.fedapay.com (ou sandbox.fedapay.com)
# Sandbox: https://sandbox-api.fedapay.com | Production: https://api.fedapay.com
FEDAPAY_API_BASE=https://sandbox-api.fedapay.com
FEDAPAY_SECRET_KEY=sk_sandbox_xxxxxxxxxxxxx
# Secret du webhook (dashboard FedaPay > Webhooks) — pour la vérification HMAC
FEDAPAY_WEBHOOK_SECRET=wh_sandbox_xxxxxxxxxxxxx
# URL de l'app (callback de retour après paiement)
APP_BASE_URL=https://bar-tender-ten.vercel.app

# Supabase (auto-injectés par Supabase)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
