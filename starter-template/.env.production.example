# ============================================================
# Configuration Production — Template
# ============================================================
# Copier ce fichier en .env.production et remplir les valeurs.
# Ce fichier PEUT être commité (pas de secrets — anon key publique).
# ============================================================

# ── Application ──────────────────────────────────────────────
VITE_APP_URL=https://your-domain.com

# ── Supabase (clés publiques — safe to commit) ───────────────
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Sentry Error Tracking ─────────────────────────────────────
# DSN public — safe to commit
VITE_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx

# ── Feature Flags ────────────────────────────────────────────
# VITE_ENABLE_XXX=true

# ============================================================
# Variables à définir dans Vercel Dashboard uniquement (secrets)
# Ne JAMAIS commiter dans ce fichier :
#   SENTRY_AUTH_TOKEN  → Vercel Dashboard → Settings → Env Vars
# ============================================================
