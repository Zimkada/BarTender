# ✅ Enable Supabase Cloud Sync
# Set to true to sync data with Supabase backend
# Set to false for offline-only mode (local SQLite)
VITE_USE_SUPABASE=true

# 🔑 Supabase Credentials
# Get these from: https://app.supabase.com → your-project → Settings → API
# VITE_SUPABASE_URL is your project URL (public, safe to commit)
# VITE_SUPABASE_ANON_KEY is your anonymous key (public, safe to commit)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ⏱️ Background Sync Configuration
# VITE_SYNC_INTERVAL: How often to sync offline operations (milliseconds)
VITE_SYNC_INTERVAL=5000

# VITE_SYNC_MAX_RETRIES: Maximum retry attempts for failed sync operations
VITE_SYNC_MAX_RETRIES=5

# ❌ Disable Debug Logs in Production
# Set to true during development to see sync debug logs
# Set to false in production (logs are stripped by Terser anyway)
VITE_SYNC_DEBUG=false

# 🎨 Enable Theme Switching
# Allow users to toggle between light/dark theme
VITE_ENABLE_THEMING=true

# 🔍 Error Tracking & Monitoring (Sentry)
# Only active in production builds (npm run build)
# Get DSN from: https://sentry.io → your-project → Settings → Client Keys
# Leave blank to disable error tracking
VITE_SENTRY_DSN="https://your-sentry-key@your-org.ingest.sentry.io/your-project-id"
